# Salesforce CLI Dotenv Plugin - Example Environment File
# Copy this file to .env and customize with your values

# Salesforce Org Configuration
SF_TARGET_ORG=your-org@example.com
SF_INSTANCE_URL=https://login.salesforce.com

# API Configuration (for connected apps)
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret

# Deployment Configuration
DEPLOYMENT_PATH=force-app/main/default
TEST_LEVEL=RunSpecifiedTests
DEPLOYMENT_OPTIONS=--test-level RunSpecifiedTests --run-tests MyTestClass

# Custom Project Variables
PROJECT_NAME=my-salesforce-project
ENVIRONMENT=development

# Database Configuration (if using external databases)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=salesforce_dev
DB_USER=postgres
DB_PASSWORD=your_password

# External API Keys
EXTERNAL_API_KEY=your_external_api_key
WEBHOOK_URL=https://your-webhook-url.com/endpoint

# Notification Settings
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
EMAIL_NOTIFICATIONS=true 