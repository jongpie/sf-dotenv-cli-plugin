{
  "name": "@jongpie/sf-dotenv-cli-plugin",
  "version": "1.0.0",
  "description": "Salesforce CLI plugin for loading environment variables from .env files",
  "author": "Jonathan Gillespie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jongpie/sf-dotenv-cli-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/jongpie/sf-dotenv-cli-plugin/issues"
  },
  "homepage": "https://github.com/jongpie/sf-dotenv-cli-plugin#readme",
  "keywords": [
    "salesforce",
    "cli",
    "plugin",
    "dotenv",
    "environment",
    "variables"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "messages/**/*",
    "npm-shrinkwrap.json",
    "oclif.manifest.json"
  ],
  "dependencies": {
    "@oclif/core": "^4.5.5",
    "dotenv": "^17.2.3",
    "fs-extra": "^11.3.2"
  },
  "devDependencies": {
    "@salesforce/core": "8.23.2",
    "@salesforce/dev-scripts": "11.0.4",
    "@salesforce/sf-plugins-core": "12.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "eslint": "^9.3.7",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "oclif": {
    "bin": "sf",
    "configMeta": "lib/shared/configMeta",
    "dirname": "sf",
    "topicSeparator": " ",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "hooks": {
      "prerun": "./lib/hooks/prerun"
    },
    "commands": "./lib/commands"
  },
  "scripts": {
    "build": "tsc -p .",
    "clean": "rm -rf lib",
    "compile": "npm run clean && npm run build",
    "demo:env-file": "node scripts/demo-env-file.js",
    "demo": "node scripts/demo.js",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "install:dev": "node scripts/install.js",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "postpack": "rm -f oclif.manifest.json",
    "prepack": "npm run compile",
    "preversion": "npm run compile",
    "test:coverage": "jest --coverage",
    "test:debug": "jest --inspect-brk",
    "test:env-file": "node scripts/test-env-file.js",
    "test:watch": "jest --watch",
    "test": "npm run compile && jest"
  },
  "type": "module"
}
